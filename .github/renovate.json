{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "docker-compose",
        "dockerfile"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "Docker non-major"
    },
    {
      "matchManagers": [
        "ansible-galaxy"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "Ansible non-major"
    }
  ]
}
